# Recommended when the domain controller certificate chain is valid:
# AD_SERVER=ldaps://dc01.example.local:636
#
# Supported fallback when LDAPS is blocked by an expired/untrusted DC certificate:
AD_SERVER=ldap://dc01.example.local:389
ALLOW_INSECURE_LDAP=true
AD_BASE_DN=DC=example,DC=local
AD_BIND_USER=svc_ad_password_sentinel@example.local
AD_BIND_PASSWORD=change-me

DIRECTORY_LABEL=Example Active Directory
WARNING_DAYS=14
NOTIFY_DAYS=14,7,3,1,0
NOTIFY_USERS=false
USER_MAIL_ALLOWED_DOMAINS=example.com

MAIL_FROM=noreply@example.com
TECH_REPORT_TO=it-support@example.com
USER_MAIL_SUBJECT=Your password will expire soon

TEST_MODE=true
ALWAYS_SEND_REPORT=true
SENDMAIL_PATH=/usr/sbin/sendmail

REPORT_DIR=/var/log/ad-password-sentinel
REPORT_CSV=ad-password-expiry-report.csv
