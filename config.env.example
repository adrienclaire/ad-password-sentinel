# LDAPS is the default. LDAP_MODE=ldap is rejected unless
# ALLOW_INSECURE_LDAP=true is explicitly set.
LDAP_MODE=ldaps
LDAP_HOST=dc01.example.local
LDAP_PORT=636
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_USER=svc_ad_password_sentinel@example.local
LDAP_PASSWORD_FILE=/etc/ad-password-sentinel/secrets/ldap-password
LDAP_CA_FILE=/etc/ssl/certs/example-ad-ca.pem
LDAP_TLS_VALIDATE=true
ALLOW_INSECURE_LDAP=false

DIRECTORY_LABEL=Example Active Directory
WARNING_DAYS=14
NOTIFY_DAYS=14,7,3,1,0
NOTIFY_USERS=false
USER_MAIL_ALLOWED_DOMAINS=example.com

MAIL_FROM=noreply@example.com
TECH_REPORT_TO=it-support@example.com
USER_MAIL_SUBJECT=Your password will expire soon

TEST_MODE=true
ALWAYS_SEND_REPORT=true

# Portable direct SMTP transport.
MAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURITY=starttls
# SMTP_USER=svc_ad_password_sentinel@example.com
# SMTP_PASSWORD_FILE=/etc/ad-password-sentinel/secrets/smtp-password

# Existing sendmail installations remain supported:
# MAIL_TRANSPORT=sendmail
# SENDMAIL_PATH=/usr/sbin/sendmail

REPORT_DIR=/var/log/ad-password-sentinel
REPORT_CSV=ad-password-expiry-report.csv
